msgid "GARAGE RAMP OPTIMIZER"
msgstr "OPTIMIZADOR DE RAMPA DE GARAJE"

msgid "Author: Efren Rodriguez Rodriguez"
msgstr "Autor: Efren Rodriguez Rodriguez"

msgid "Web:   https://efrenrodriguezrodriguez.com/"
msgstr "Web:   https://efrenrodriguezrodriguez.com/"

msgid "Enter the dimensions of the ramp you want to build."
msgstr "Introduce las dimensiones de la rampa que quieres construir."

msgid "Car data (press Enter to use the defaults for a Seat Leon FR 2025):"
msgstr "Datos del coche (pulsa Enter para usar los valores por defecto del Seat Leon FR 2025):"

msgid "Total rise between the garage floor and the street (cm)"
msgstr "Desnivel total entre el suelo del garaje y la calle (cm)"

msgid "Horizontal length of the ramp (cm)"
msgstr "Longitud horizontal de la rampa (cm)"

msgid "Ground clearance of the lowest underbody point (cm)"
msgstr "Altura libre del bajo del coche (cm)"

msgid "Wheelbase / distance between axles (cm)"
msgstr "Batalla / distancia entre ejes (cm)"

msgid "Front overhang (axle to lowest front point, cm)"
msgstr "Voladizo delantero (eje al frontal mas bajo, cm)"

msgid "Rear overhang (0 if it does not scrape, cm)"
msgstr "Voladizo trasero (0 si no roza, cm)"

msgid "Ramp:  rise = {rise} cm,  run = {run} cm,  mean grade = {pct:.1f} % ({deg:.2f} degrees)"
msgstr "Rampa: desnivel = {rise} cm,  longitud = {run} cm,  pendiente media = {pct:.1f} % ({deg:.2f} grados)"

msgid "Car:   ground clearance = {clearance} cm,  wheelbase = {wheelbase} cm,"
msgstr "Coche: altura libre = {clearance} cm,  batalla = {wheelbase} cm,"

msgid "       front overhang = {fo} cm,  rear overhang = {ro} cm"
msgstr "       voladizo delantero = {fo} cm,  voladizo trasero = {ro} cm"

msgid "I do not understand that number. Try again."
msgstr "No se entiende ese numero. Intenta de nuevo."

msgid "The value must be greater than {minimum}. Try again."
msgstr "El valor debe ser mayor que {minimum}. Intenta de nuevo."

msgid "Input cancelled."
msgstr "Entrada cancelada."

msgid "ERROR: rise and run must be positive."
msgstr "ERROR: el desnivel y la longitud deben ser positivos."

msgid "WARNING: rise is greater than or equal to run. The mean grade would be >= 100 % (45 degrees or more), which is not realistic for a car."
msgstr "AVISO: el desnivel es mayor o igual que la longitud. La rampa tendria una pendiente media >= 100 % (45 grados o mas), que no es realista para un coche."

msgid "Garage ramp profile optimizer. Computes the optimal ramp shape to avoid scraping, using several methods (linear ramp, two arcs + straight, 3 segments, 4 segments and free-form smooth curve)."
msgstr "Optimizador del perfil de una rampa de garaje. Calcula la forma optima para evitar que el coche roce, usando varios metodos (rampa lineal, dos arcos + recta, 3 tramos, 4 tramos y curva suave)."

msgid "Total rise between the garage floor and the street (cm). Can also be passed as the first positional argument."
msgstr "Desnivel total entre el suelo del garaje y la calle (cm). Tambien puede pasarse como primer argumento posicional."

msgid "Horizontal length of the ramp (cm). Can also be passed as the second positional argument."
msgstr "Longitud horizontal de la rampa (cm). Tambien puede pasarse como segundo argumento posicional."

msgid "Ground clearance of the lowest underbody point on flat ground (cm)."
msgstr "Altura libre del bajo del coche sobre el suelo, en plano (cm)."

msgid "Distance between the front and rear axles (cm)."
msgstr "Distancia entre el eje delantero y el trasero (cm)."

msgid "Distance from the front axle to the lowest front edge (bumper / lip, cm)."
msgstr "Distancia desde el eje delantero al borde inferior del frontal (paragolpes / faldon, cm)."

msgid "Distance from the rear axle to the lowest rear edge (cm). Leave at 0 if the rear bumper sits higher than the underbody."
msgstr "Distancia desde el eje trasero al borde inferior trasero (cm). Dejar en 0 si el paragolpes trasero queda mas alto que el bajo."

msgid "Shortcut: 'ramp_optimizer RISE RUN' is equivalent to -d RISE -l RUN."
msgstr "Atajo: 'ramp_optimizer DESNIVEL LONGITUD' equivalente a -d DESNIVEL -l LONGITUD."

msgid "Output language for the GUI, the console messages and the blueprint plots ('en' = English, 'es' = Spanish). Default: 'en' (or 'es' if compiled with --spanish)."
msgstr "Idioma de la GUI, los mensajes de consola y los planos ('en' = ingles, 'es' = espanol). Por defecto: 'en' (o 'es' si se compilo con --spanish)."

msgid "--- {name} ---"
msgstr "--- {name} ---"

msgid "Linear ramp (current geometry)"
msgstr "Rampa lineal (geometria actual)"

msgid "Optimal three-segment ramp (two arcs + straight)"
msgstr "Rampa optima de 3 segmentos (2 arcos + recta)"

msgid "Optimal three-slope ramp"
msgstr "Rampa optima de 3 tramos rectos"

msgid "Optimal four-slope ramp"
msgstr "Rampa optima de 4 tramos rectos"

msgid "Optimal smooth ramp (PCHIP monotone spline)"
msgstr "Rampa suave optima (spline monotono PCHIP)"

msgid "  worst chassis-between-wheels clearance:    {value}"
msgstr "  peor holgura del bajo (entre ruedas):     {value}"

msgid "  worst overhang (bumper) clearance:         {value}"
msgstr "  peor holgura del paragolpes (voladizo):   {value}"

msgid "      occurs at x = {at_x:6.1f} cm  (rear wheel at x = {at_rear:6.1f} cm)"
msgstr "      ocurre en x = {at_x:6.1f} cm (rueda trasera en x = {at_rear:6.1f} cm)"

msgid "  (SCRATCHES)"
msgstr "  (ROZA)"

msgid "  (touching)"
msgstr "  (justo)"

msgid "Searching the design space (two arcs + straight) ..."
msgstr "Buscando en el espacio de diseno (2 arcos + recta) ..."

msgid "Best parameters:"
msgstr "Mejores parametros:"

msgid "  theta (max slope of the straight middle)  = {deg:.2f} degrees   (tan = {pct:.1f} %)"
msgstr "  theta (pendiente max. del tramo recto) = {deg:.2f} grados   (tan = {pct:.1f} %)"

msgid "  R_bottom (lower-arc radius)               = {value:7.1f} cm"
msgstr "  R_inferior (radio del arco inferior)   = {value:7.1f} cm"

msgid "  R_top    (upper-arc radius)               = {value:7.1f} cm"
msgstr "  R_superior (radio del arco superior)   = {value:7.1f} cm"

msgid "  Length of the straight middle (along ramp) = {value:7.1f} cm"
msgstr "  Longitud del tramo recto (sobre rampa) = {value:7.1f} cm"

msgid "Segment endpoints (cm):"
msgstr "Extremos de cada tramo (cm):"

msgid "  start of bottom arc      : x =   0.0,  y =   0.0"
msgstr "  inicio arco inferior     : x =   0.0,  y =   0.0"

msgid "  bottom arc -> straight   : x = {x:5.1f},  y = {y:5.1f}"
msgstr "  arco inferior -> recta   : x = {x:5.1f},  y = {y:5.1f}"

msgid "  straight -> top arc      : x = {x:5.1f},  y = {y:5.1f}"
msgstr "  recta -> arco superior   : x = {x:5.1f},  y = {y:5.1f}"

msgid "  end of top arc           : x = {x:5.1f},  y = {y:5.1f}"
msgstr "  fin del arco superior    : x = {x:5.1f},  y = {y:5.1f}"

msgid "Searching the best three-slope profile ..."
msgstr "Buscando el mejor perfil de 3 tramos rectos ..."

msgid "Best parameters (3 slopes):"
msgstr "Mejores parametros (3 tramos):"

msgid "  break point 1:  x1 = {x:5.1f} cm,  y1 = {y:5.2f} cm"
msgstr "  punto de quiebre 1:  x1 = {x:5.1f} cm,  y1 = {y:5.2f} cm"

msgid "  break point 2:  x2 = {x:5.1f} cm,  y2 = {y:5.2f} cm"
msgstr "  punto de quiebre 2:  x2 = {x:5.1f} cm,  y2 = {y:5.2f} cm"

msgid "  slope 1 (bottom):    {deg:5.2f} degrees ({pct:.1f} %)"
msgstr "  tramo 1 (inferior):  {deg:5.2f} grados ({pct:.1f} %)"

msgid "  slope 2 (middle):    {deg:5.2f} degrees ({pct:.1f} %)"
msgstr "  tramo 2 (medio):     {deg:5.2f} grados ({pct:.1f} %)"

msgid "  slope 3 (top):       {deg:5.2f} degrees ({pct:.1f} %)"
msgstr "  tramo 3 (superior):  {deg:5.2f} grados ({pct:.1f} %)"

msgid "  fillet radius at every kink: {fillet:.0f} cm"
msgstr "  radio de la curva en cada quiebre: {fillet:.0f} cm"

msgid "Searching in parallel: 4-slope ramp and free-form smooth curve ..."
msgstr "Buscando en paralelo: 4 tramos rectos y curva suave libre ..."

msgid "Best parameters (4 slopes):"
msgstr "Mejores parametros (4 tramos):"

msgid "  break point {k}:  x{k} = {x:5.1f} cm,  y{k} = {y:5.2f} cm"
msgstr "  punto de quiebre {k}:  x{k} = {x:5.1f} cm,  y{k} = {y:5.2f} cm"

msgid "  slope {i}: {deg:5.2f} degrees ({pct:5.1f} %)   length {L:.1f} cm"
msgstr "  tramo {i}: {deg:5.2f} grados ({pct:5.1f} %)   longitud {L:.1f} cm"

msgid "Best control points of the smooth curve:"
msgstr "Mejores puntos de control de la curva suave:"

msgid "  {i:>2}  {x:8.1f}  {y:8.2f}  {tag}"
msgstr "  {i:>2}  {x:8.1f}  {y:8.2f}  {tag}"

