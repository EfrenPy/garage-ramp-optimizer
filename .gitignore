# PyInstaller build output
build/
dist/
*.spec

# MkDocs build output
_site/

# Spanish-build marker (created on the fly by `build_exe.py --spanish`)
_lang_es.flag

# Generated outputs of running the optimiser.  Re-generated on every
# run, so they should never be committed.  An example screenshot used
# by the README lives in `docs/` and is exempt from these rules.
/ramp_blueprint*.png
/ramp_blueprint*.pdf
/ramp_profile.png
/ramp_profile.pdf
/ramp_offsets*.csv

# Python caches
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.venv/
venv/

# Editor / OS scratch
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
